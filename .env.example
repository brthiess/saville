# Directus API base URL used by the Vue frontend.
# Local example: http://localhost:8055
# Render example: https://your-directus-service.onrender.com
VITE_DIRECTUS_URL=http://localhost:8055

# Optional explicit admin login URL used by the "Forgot Password" link.
# Leave blank to default to: ${VITE_DIRECTUS_URL}/admin/login
VITE_DIRECTUS_ADMIN_URL=

VITE_DIRECTUS_ENFORCE_MEMBER_ROLE=false
VITE_DIRECTUS_MEMBER_ROLE_ALLOWLIST=Curler,Customer,Member
