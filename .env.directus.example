# Directus instance settings
KEY=replace-with-a-long-random-key
SECRET=replace-with-a-long-random-secret

# Local example: http://localhost:8055
# Render example: https://your-directus-service.onrender.com
PUBLIC_URL=http://localhost:8055

# Local-only host port used by docker-compose
DIRECTUS_PORT=8055

# Initial admin user (created at first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Public registration role assignment is configured in Directus Admin settings
# (for /users/register requests). Set the default registration role to Curler there.

# Database settings (used by both Directus and Postgres service)
DB_CLIENT=pg

# Local Docker Compose value: database
# Render value: set from managed Postgres host
DB_HOST=database

# Local Docker Compose value: 5432
# Render value: set from managed Postgres port
DB_PORT=5432

# Local Docker Compose value: directus
# Render value: set from managed Postgres database name
DB_DATABASE=directus

# Local Docker Compose value: directus
# Render value: set from managed Postgres user
DB_USER=directus

# Local Docker Compose value: directus
# Render value: set from managed Postgres password
DB_PASSWORD=directus

# Dev-friendly CORS for the Vue app
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173
